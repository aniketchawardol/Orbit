# --- Django ---
SECRET_KEY=dev-insecure-change-me
DEBUG=1
ALLOWED_HOSTS=*
GUNICORN_WORKERS=3
SEED_ON_BOOT=1

# --- Postgres (read by both the db container and Django) ---
POSTGRES_DB=loop
POSTGRES_USER=loop
POSTGRES_PASSWORD=loop-dev-password
POSTGRES_HOST=db
POSTGRES_PORT=5432

# --- AI service: AI_MOCK=1 → deterministic fakes; AI_MOCK=0 → real calls ---
AI_MOCK=1
AI_SERVICE_URL=
AI_API_KEY=

# --- Optional Redis cache (leave empty = in-process LocMem) ---
REDIS_URL=

# --- Media: 0 = local docker volume, 1 = S3 (set bucket + region) ---
USE_S3=0
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=ap-south-1
AWS_S3_CUSTOM_DOMAIN=
