SECRET_KEY=change-me
DEBUG=0
ALLOWED_HOSTS=yourdomain.com
CSRF_TRUSTED_ORIGINS=https://yourdomain.com
SECURE_COOKIES=0
GUNICORN_WORKERS=3
SEED_ON_BOOT=1
POSTGRES_DB=loop
POSTGRES_USER=loop
POSTGRES_PASSWORD=strong-password
POSTGRES_HOST=db
POSTGRES_PORT=5432
AI_MOCK=0
AI_SERVICE_URL=https://ai.internal.example.com
AI_API_KEY=sk-...
REDIS_URL=redis://redis:6379/0

# --- Async grading workers (Celery on Redis) ---
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
CELERY_CONCURRENCY=4
# Run grading tasks inline instead of on the worker (tests / no broker):
CELERY_TASK_ALWAYS_EAGER=0

# --- AI return grading ---
# Provider: auto|mock|gemini|openai|modal (auto = gemini if key set, else mock)
GRADING_VLM_PROVIDER=auto
GRADING_EMBEDDING_PROVIDER=phash
GRADING_VLM_TIMEOUT=30
# Gemini via Google's OpenAI-compatible endpoint:
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# Optional alternates (same OpenAI protocol):
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# MODAL_BASE_URL=
# MODAL_API_KEY=
# MODAL_MODEL=

# --- Return window ---
RETURN_WINDOW_DAYS=7

# --- Media on S3 (USE_S3=0 → local docker volume) ---
USE_S3=0
AWS_STORAGE_BUCKET_NAME=loop-media-yourname
AWS_S3_REGION_NAME=ap-south-1
# Leave blank to use the bucket URL; set to a CloudFront domain when added.
AWS_S3_CUSTOM_DOMAIN=
# On EC2 prefer an IAM instance role (no keys needed). Keys only for local S3 testing:
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
